# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored. `scripts/01-generate-ssh-key.sh`, `scripts/02-deploy.sh`,
# and `scripts/03-tunnel-ghes-mgmt.sh` auto-source `.env` if present.

# ---- Required ----
# Azure subscription ID where the test environment will be deployed.
AZURE_SUBSCRIPTION_ID=

# ---- Optional overrides ----
# Resource group name (default: rg-ghestest-jpe).
# RG_NAME=rg-ghestest-jpe

# Azure region (default: japaneast). Bicep param `location` default also applies.
# LOCATION=japaneast

# SSH key file basename in ~/.ssh (default: ghestest_id_ed25519).
# Both 01-generate-ssh-key.sh (key generation) and 02-deploy.sh (key reading) honor this.
# SSH_KEY_NAME=ghestest_id_ed25519

# Override the full private key path (default: ~/.ssh/${SSH_KEY_NAME}).
# SSH_PRIVATE_KEY_PATH=

# Override the full public key path (default: ${SSH_PRIVATE_KEY_PATH}.pub).
# SSH_PUBLIC_KEY_PATH=

# Comment baked into the SSH key (default: ghestest-admin@<hostname>).
# SSH_KEY_COMMENT=ghestest-admin

# ---- Tunnel script (03-tunnel-ghes-mgmt.sh) overrides ----
# GHES VM name (default: vm-ghestest-ghes; auto-detected from latest deployment).
# GHES_VM_NAME=vm-ghestest-ghes

# Pre-resolved GHES VM resource ID (skip auto-detection).
# GHES_VM_ID=

# Bastion name (default: auto-detected from latest deployment or RG).
# BASTION_NAME=

# Tunnel mode: mgmt (default; localhost:8443 → :8443) or ssh (use --ssh / --admin-shell flags).
# MODE=mgmt

# Local port for the tunnel (default: matches resource port).
# LOCAL_PORT=

# SSH resource port. Use 122 for GHES admin shell (or run with `--admin-shell`).
# SSH_RESOURCE_PORT=22
