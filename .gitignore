# Deployment logs (may contain subscription IDs, FQDNs, owner names)
# Use logs/* with !logs/.gitkeep so the directory is tracked but content is ignored.
logs/*
!logs/.gitkeep
*.log

# Local environment configuration
.env
.env.local
.env.*.local

# SSH keys (should never be committed)
*.pem
*_id_ed25519
*_id_ed25519.pub
*_id_rsa
*_id_rsa.pub

# Bicep build artifacts
*.bicep.json

# IDE / editor
.vscode/
.idea/
*.swp
*~
.DS_Store

# Python / Node tooling caches
__pycache__/
*.pyc
node_modules/

# Local Copilot session state — must NOT be pushed
.copilot/
